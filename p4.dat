3C090102 // lui $t1, 0x0102      ; Row 3
35290304 // ori $t1, $t1, 0x0304 
AD09000C // sw  $t1, 12($t0)     

//Load Matrix B column wise
3C0AFFFF // lui $t2, 0xFFFF      ; Col 0
354AFFFF // ori $t2, $t2, 0xFFFF 
AD0A0010 // sw  $t2, 16($t0)     

3C0A5555 // lui $t2, 0x5555      ; Col 1
354A5555 // ori $t2, $t2, 0x5555 
AD0A0014 // sw  $t2, 20($t0)     

3C0AAAAA // lui $t2, 0xAAAA      ; Col 2
354AAAAA // ori $t2, $t2, 0xAAAA 
AD0A0018 // sw  $t2, 24($t0)     

3C0A0403 // lui $t2, 0x0403      ; Col 3
354A0201 // ori $t2, $t2, 0x0201 
AD0A001C // sw  $t2, 28($t0)     

//Trigger NPU
200B0001 // addi $t3, $zero, 1
