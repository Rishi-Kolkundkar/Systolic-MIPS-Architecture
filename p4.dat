
3C088000 // lui $t0, 0x8000      ; Base Address

//Load Matrix A row wise
3C09FFFF // lui $t1, 0xFFFF      ; Row 0
3529FFFF // ori $t1, $t1, 0xFFFF
AD090000 // sw  $t1, 0($t0)      

3C09AAAA // lui $t1, 0xAAAA      ; Row 1
3529AAAA // ori $t1, $t1, 0xAAAA 
AD090004 // sw  $t1, 4($t0)      

